    {
      "name": "Create New User",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "var random = Math.random().toString(36).substring(2)\r",
              "var userName = \"Surya\"+random;\r",
              "var userEmail= \"Surya\"+random+\"@gmail.com\";\r",
              "\r",
              "pm.environment.set(\"email_env\",userEmail);\r",
              "pm.environment.set(\"name_env\",userName);\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "jsonData = JSON.parse(responseBody)\r",
              "pm.environment.set(\"userid_env\", jsonData.id)"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \r\n    \"name\": \"{{name_env}}\",\r\n    \"email\": \"{{email_env}}\",\r\n    \"gender\": \"male\",\r\n    \"status\": \"Pass\"\r\n  }",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "http://localhost:3000/users",
          "protocol": "http",
          "host": [
            "localhost"
          ],
