    {
      "name": "Get Single Student Data",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// status code validation\r",
              "pm.test(\"Status code is 200 or 201\", function () {\r",
              "    pm.expect(pm.response.code).to.be.oneOf([200,201]);\r",
              "}\r",
              ");\r",
              "// header validation type of content \r",
              "pm.test(\"Content-Type header is present or not \" ,()=>\r",
              "\t{\r",
              "\tpm.response.to.have.header(\"Content-Type\");\r",
              "\t}\r",
              "\t);\r",
              "//value of header validation\r",
              "pm.test(\"check the value of content-type\", ()=>\r",
              "{\r",
              " pm.expect(pm.response.headers.get(\"Content-Type\")).to.eql(\"application/json\");\r",
              "}\r",
              ");\r",
              "// cookies validation \r",
              "pm.test(\"cookies language not available\", ()=>\r",
              "{\r",
              " pm.expect(pm.cookies.has('language')).to.be.false;\r",
              "}\r",
              ");\r",
              "// cookies validation value \r",
              "pm.test(\"cookies language  available is english\", ()=>\r",
              "{\r",
              " pm.expect(pm.cookies.get('language')).to.eql('en-gb');\r",
              "}\r",
              ");\r",
              "//responce time\r",
              "pm. test (\"responce time is below 50 \",()=>\r",
              "\t{\r",
              "\tpm.expect(pm.response.responseTime).to.be.below(50);\r",
              "\t});\r",
              "\r",
              "const jsonData = pm .response.json()\r",
              "//data type validation\r",
              "pm.test(\"Test data type of response\",()=>\r",
              "\t{\r",
              "\tpm.expect(jsonData).to.be.an(\"object\");\r",
              "\tpm.expect(jsonData.name).to.be.a(\"string\");\r",
              "\tpm.expect(jsonData.id).to.be.a(\"string\");\r",
              "\tpm.expect(jsonData.course).to.be.an(\"array\");\r",
              "\r",
              "\t});\r",
              "//array values validation\r",
              "pm.test(\"Test array properties sinle and multiple data in array\",()=>\r",
              "{\r",
              "pm.expect(jsonData.course).to.include(\"Data Science\");\r",
              "pm.expect(jsonData.course).to.have.members([\"Computer Science\",\"Data Science\"]);  \r",
              "});\r",
              "\r",
              "// values in a json object \r",
              "pm.test(\"Test the values in a json object\",()=>\r",
              "{\r",
              "    pm.expect(jsonData.id).to.eql(\"1\");\r",
              "    pm.expect(jsonData.name).to.eql(\"Rahul\");\r",
              "    pm.expect(jsonData.age).to.eql(21);\r",
              "    pm.expect(jsonData.course[0]).to.eql(\"Computer Science\");\r",
              "    pm.expect(jsonData.course[1]).to.eql(\"Data Science\");\r",
              "    pm.expect(jsonData.grade).to.eql(\"A\");\r",
              "});\r",
              "\r",
              "\r",
              "// json schema validation \r",
              "\r",
              "var schema = {\r",
              "  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r",
              "  \"type\": \"object\",\r",
              "  \"properties\": {\r",
              "    \"id\": {\r",
              "      \"type\": \"string\"\r",
              "    },\r",
              "    \"name\": {\r",
              "      \"type\": \"string\"\r",
              "    },\r",
              "    \"age\": {\r",
              "      \"type\": \"integer\"\r",
              "    },\r",
              "    \"course\": {\r",
              "      \"type\": \"array\",\r",
              "      \"items\": [\r",
              "        {\r",
              "          \"type\": \"string\"\r",
              "        },\r",
              "        {\r",
              "          \"type\": \"string\"\r",
              "        }\r",
              "      ]\r",
              "    },\r",
              "    \"grade\": {\r",
              "      \"type\": \"string\"\r",
              "    }\r",
              "  },\r",
              "  \"required\": [\r",
              "    \"id\",\r",
              "    \"name\",\r",
              "    \"age\",\r",
              "    \"course\",\r",
              "    \"grade\"\r",
              "  ]\r",
              "}\r",
              "\r",
              "pm.test(\"Test for Schema validation\",()=>\r",
              "{\r",
              "pm.expect(tv4.validate(jsonData, schema)).to.be.true;\r",
              "})\r",
              "\r",
              "\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
